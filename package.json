{
  "name": "generador-avisos-impuestos",
  "private": true,
  "version": "1.1.9",
  "description": "Generador de avisos fiscales para clientes con lectura de capturas mediante IA",
  "author": "Asesoría E. Marín",
  "type": "module",
  "main": "main-electron.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder build --win --publish never",
    "electron:publish": "npm run build && electron-builder build --win --publish always"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.asesoria.generadoravisos",
    "productName": "Generador de Avisos Fiscales",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main-electron.cjs",
      "package.json",
      "assets/app.ico",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Generador de Avisos Fiscales",
      "installerIcon": "assets/app.ico",
      "uninstallerIcon": "assets/app.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Soakkk",
      "repo": "Avisos-clientes-resultados-impuestos-releases",
      "releaseType": "release"
    }
  },
  "allowScripts": {
    "@google/genai@2.10.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true
  }
}
